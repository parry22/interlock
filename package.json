{
  "name": "interlock",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lifecycle": "node --env-file=.env.local --import tsx backend/scripts/run-lifecycle.ts",
    "test": "node --import tsx --test src/lib/interlock/__tests__/*.test.mjs src/lib/connectors/__tests__/*.test.mjs",
    "test:dsl": "node --import tsx --test src/lib/interlock/__tests__/dsl.test.mjs",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "node --env-file=.env.local --import tsx backend/scripts/db-migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:health": "node --env-file=.env.local --import tsx backend/scripts/db-health.ts",
    "seed:agents": "node --env-file=.env.local --import tsx backend/scripts/seed-agents.ts"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.1.3",
    "@hugeicons/react": "^1.1.6",
    "@mysten/sui": "^2.17.0",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "@types/pg": "^8.20.0",
    "ai": "^6.0.219",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "ethers": "^6.17.0",
    "jose": "^6.2.3",
    "next": "16.2.6",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vercel": "^54.20.1"
  }
